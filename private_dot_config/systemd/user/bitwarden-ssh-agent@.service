[Unit]
Description=Bitwarden SSH agent relay for one WSL connection
CollectMode=inactive-or-failed

[Service]
Type=simple
Environment="PATH=/mnt/c/Program Files/PowerShell/7"
ExecStart=%h/.local/bin/mise --no-config --no-env --no-hooks --silent exec conda:socat -- socat STDIO 'EXEC:pwsh.exe -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -Command "mise --no-config --no-env --no-hooks --silent exec github:albertony/npiperelay -- npiperelay.exe --ei --s //./pipe/openssh-ssh-agent",nofork'
StandardInput=socket
StandardOutput=socket
StandardError=journal
TimeoutStopSec=5s
